# Blob input/output
BLOB_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
BLOB_CONTAINER_IN=calls
BLOB_CONTAINER_OUT=reports
BLOB_CONNECTION_STRING=

# Process mode
INPUT_SOURCE=blob
INPUT_BLOB_NAME=
INPUT_PREFIX=
LOCAL_AUDIO_PATH=
LOCAL_AUDIO_DIR=
RUBRIC_BLOB_PATH=rubric/rubric.json
RUBRIC_LOCAL_PATH=
OUTPUT_DIR=reports/quality_checks
OUTPUT_TO_BLOB=true
INCLUDE_TRANSCRIPT=true
JUDGE_CONCURRENCY=4

# Speech (Azure AI Speech)
SPEECH_KEY=
SPEECH_REGION=
SPEECH_ENDPOINT=
# Alias forms are also supported by code:
# AZURE_SPEECH_KEY / AZURE_SPEECH_REGION / AZURE_SPEECH_ENDPOINT
# If using az login (no key), leave SPEECH_KEY empty and set SPEECH_ENDPOINT only.
SPEECH_CUSTOM_ENDPOINT_ID=
SPEECH_LANGUAGES=zh-TW,en-US
# Alias for language locale list is also supported: AZURE_SPEECH_LOCALE
PHRASE_LIST_PATH=assets/phrase_list.txt
CORRECTIONS_PATH=assets/corrections.json

# Voice Live API (STT benchmark)
AZURE_VOICELIVE_ENDPOINT=https://<resource>.services.ai.azure.com/
AZURE_VOICELIVE_MODEL=gpt-5.4
AZURE_VOICELIVE_API_KEY=

# Azure OpenAI
AOAI_API_KEY=
# Supports both formats:
# 1) Classic Azure OpenAI endpoint: https://<resource>.openai.azure.com
# 2) New v1 endpoint: https://<resource>.openai.azure.com/openai/v1
AOAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AOAI_DEPLOYMENT=gpt-4.1-mini
AOAI_API_VERSION=2024-10-21
AOAI_USE_ENTRA_ID=false
AOAI_SCOPE=https://cognitiveservices.azure.com/.default

# GPT audio transcribe provider (gpt-audio-transcribe)
# Overrides AOAI_DEPLOYMENT for the audio transcription endpoint specifically.
GPT_AUDIO_TRANSCRIBE_DEPLOYMENT=gpt-4o-transcribe
# Cost estimate override (USD per audio-hour, default proxy: 72.0)
GPT_AUDIO_TRANSCRIBE_HOURLY_USD=

# Azure Speech REST fast-transcription provider (azure-speech-stt-rest)
# Uses the same cognitiveservices.azure.com endpoint as real-time STT.
# API version for POST /speechtotext/transcriptions:transcribe
AZURE_SPEECH_REST_API_VERSION=2024-11-15
# Cost estimate override (USD per audio-hour, default: 0.33)
AZURE_SPEECH_STT_REST_HOURLY_USD=

# Azure Speech real-time SDK cost override (USD per audio-hour, default: 1.0)
AZURE_SPEECH_STT_REALTIME_HOURLY_USD=

# UC2 hosted-agent runtime (use these locally; Foundry injects its own values when hosted)
VOICE_ASSIST_PROJECT_ENDPOINT=
VOICE_ASSIST_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
VOICE_ASSIST_STT_SERVICE=
VOICE_ASSIST_STT_MODEL=Azure Speech - Text to Speech
VOICE_ASSIST_WINDOW_TURNS=12
VOICE_ASSIST_MAX_CARDS=3
VOICE_ASSIST_PROMPT_PATH=assets/uc2_agent_prompt.txt

# UC2 also falls back to SPEECH_ENDPOINT when VOICE_ASSIST_STT_SERVICE is not set.
